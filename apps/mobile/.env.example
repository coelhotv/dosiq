# Variáveis públicas do app mobile
# Copie para .env.local e preencha com seus valores
# RE-004: EXPO_PUBLIC_* são públicas e ficam no bundle — NUNCA colocar segredos aqui

# URL do projeto Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Chave anônima pública do Supabase (pode ficar no bundle)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Ambiente do app (development | preview | production)
EXPO_PUBLIC_APP_ENV=development

# --------------------------------------------------------------------------
# Segredos NÃO devem usar EXPO_PUBLIC_* — usar `eas secret:create` para:
#   - credenciais de submit Apple/Google
#   - tokens internos de integração
# --------------------------------------------------------------------------
